APP_NAME="africhart-emr"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=africhart_emr
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
# Mail (verification codes, admin + backup notifications) is queued so the front
# desk never waits on SMTP. Requires a running worker:
#   php artisan queue:work --tries=3
# Use `sync` only for local dev where you don't want to run a worker.
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# SMTP — used for email verification codes and password-reset links.
# Port 465 requires MAIL_ENCRYPTION=ssl.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Registration invite codes — only people with the matching code can register as that role.
# Set your own secret values here; never commit real codes.
REGISTER_CODE_ADMIN=
REGISTER_CODE_DOCTOR=
REGISTER_CODE_NURSE=
REGISTER_CODE_RECEPTIONIST=

# Off-site backup storage (S3-compatible: AWS S3, Backblaze B2, Cloudflare R2, Wasabi).
# Set AWS_ENDPOINT for non-AWS providers; leave BACKUP_OFFSITE_DISK blank to keep
# backups local-only. See docs/backups-and-ops.md.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Backups (spatie/laravel-backup)
BACKUP_OFFSITE_DISK=
BACKUP_NOTIFICATION_EMAIL=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
