                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "temperature": {
                                        "type": "number",
                                        "example": 37.2
                                    },
                                    "blood_pressure": {
                                        "type": "string",
                                        "example": "120/80"
                                    },
                                    "pulse_rate": {
                                        "type": "integer",
                                        "example": 72
                                    },
                                    "weight": {
                                        "type": "number",
                                        "example": 68
                                    },
                                    "height": {
                                        "type": "number",
                                        "example": 170
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Vitals recorded"
