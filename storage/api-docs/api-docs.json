        "/consultations/{consultation}/vitals": {
            "patch": {
                "tags": [
                    "Consultations"
                ],
                "summary": "Record vitals (doctor, nurse or admin)",
                "operationId": "c2d88e2c4778ea9cbd66b7d96b66803c",
                "parameters": [
                    {
                        "name": "consultation",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
